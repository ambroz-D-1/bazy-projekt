@startuml
title Diagram przypadkow uzycia – System Analizy Behawioralnej
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "Uzytkownik" as U
actor "Administrator" as A
actor "System analizy" as S

  package "Aplikacja wspolpracujaca" {
    usecase "Przegladaj feed postow"                      as UC1
    usecase "Polub / skomentuj / udostepnij / dodaj post" as UC2
    usecase "Wyswietl wlasne polubienia"                  as UC3
    usecase "Wyswietl wlasne komentarze"                  as UC4
    usecase "Wyswietl wlasne udostepnienia"               as UC5
  }

rectangle "System Analizy Behawioralnej Platformy Spolecznosciowej" {
  package "Zarzadzanie przez admina" {
    usecase "Zarzadzaj uzytkownikami"              as UC6
    usecase "Zarzadzaj postami"                    as UC7
    usecase "Przegladaj interakcje"                as UC8
    usecase "Przegladaj profile behawioralne"      as UC9
    usecase "Filtruj uzytkownikow wg profilu"      as UC10
    usecase "Przegladaj raport ostrzezen"          as UC11
    usecase "Generuj raport uzytkownika"           as UC12
    usecase "Przegladaj ranking postow"            as UC13
  }
  package "Analiza automatyczna" {
    usecase "Oblicz profil behawioralny"                as UC14
    usecase "Wykryj tresci ekstremistyczne"             as UC15
    usecase "Buduj klastry uzytkownikow"                as UC16
    usecase "Buduj digital fingerprint"                 as UC17
    usecase "Generuj ranking postow wg zaangazowania"   as UC18
  }
}

U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5

A --> UC6
A --> UC7
A --> UC8
A --> UC9
A --> UC10
A --> UC11
A --> UC12
A --> UC13

S --> UC14
S --> UC15
S --> UC16
S --> UC17
S --> UC18

UC2  ..> UC14 : <<include>>
UC9  ..> UC14 : <<include>>
UC11 ..> UC15 : <<include>>
UC12 ..> UC14 : <<include>>
UC10 ..> UC9  : <<include>>
UC13 ..> UC18 : <<include>>

@enduml

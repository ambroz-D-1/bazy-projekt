@startuml
title Diagram czynnosci – Zarzadzanie ogloszeniem przez Agenta

|Agent|
|System OBDN|

|Agent|
start
:Loguje sie do systemu;
:Wybiera nieruchomosc\nz bazy lub tworzy nowa;

|System OBDN|
:Weryfikuje uprawnienia agenta\n(ROLA_ID = AGENT lub DEWELOPER);

if (Ma uprawnienia?) then (tak)

  |Agent|
  :Wypelnia formularz ogloszenia:\n- typ (sprzedaz / wynajem)\n- tytul i opis\n- cena\n- data wygasniecia;

  |System OBDN|
  :Waliduje dane:\n- nieruchomosc istnieje w bazie?\n- cena > 0?\n- data wygasniecia > dzis?;

  if (Dane poprawne?) then (tak)
    :INSERT INTO OGLOSZENIA\n(STATUS = 'ROBOCZE');

    |Agent|
    if (Opublikowac od razu?) then (tak)
      |System OBDN|
      :UPDATE STATUS = 'AKTYWNE';
      :Oblicz HASH_DEDUPLIKACJI;
      :Wywolaj SP_DEDUPLIKUJ_OGLOSZENIA\n(wykrywanie duplikatow);
    else (nie)
      :Ogloszenie zostaje ROBOCZE;
    endif

    :Wyswietl potwierdzenie\npublikacji;

    |Agent|
    :Przegladanie aktywnych ofert\n(V_PORTFEL_AGENTA);

    if (Zmiana ceny?) then (tak)
      |System OBDN|
      :INSERT INTO HISTORIA_CEN_OGLOSZEN\n(cena_poprzednia, cena_nowa);
      :UPDATE OGLOSZENIA.CENA;
    endif

    if (Rezygnacja / sprzedaz?) then (tak)
      |System OBDN|
      :UPDATE STATUS = 'WYCOFANE'\nlub 'SPRZEDANE' / 'WYNAJETE';
    endif

  else (nie)
    :Wyswietl bledy walidacji;
  endif

else (nie)
  :Odmow dostepu;
endif

stop
@enduml

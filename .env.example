# ─── Oracle XE (Docker) ───────────────────────────────────────────────────────
# Haslo uzytkownika SYS / ADMIN w kontenerze (ORACLE_PASSWORD wymagane przez gvenzl/oracle-xe)
ORACLE_PASSWORD=zmien_to_haslo_SYS

# Haslo uzytkownika schematu PEGASUS (uzywane w 00_setup_schema.sql i przez testy)
PEGASUS_PASSWORD=zmien_to_haslo_PEGASUS

# Haslo uzytkownika schematu OBDN (uzywane w 00_setup_schema.sql i przez testy)
OBDN_PASSWORD=zmien_to_haslo_OBDN

# ─── Testy (pytest / CI) ──────────────────────────────────────────────────────
# Ponizsze zmienne sa uzywane przez pegasus/tests/test_database.py i obdn/tests/test_database.py
# Lokalnie: test_database.py uzywa ORACLE_PASSWORD jako fallback dla ORACLE_SYS_PASSWORD
# W GitHub Actions sa ustawiane automatycznie przez ci-tests.yml
#
# ORACLE_SYS_PASSWORD=<ta sama wartosc co ORACLE_PASSWORD>  (opcja; jesli brak, uzywa ORACLE_PASSWORD)
# DB_HOST=localhost
# DB_PORT=1522
# DB_SERVICE=XEPDB1
# DB_URL=USER/PASSWD@HOST:PORT/DATABASE
# ─── Oracle XE (Docker) ───────────────────────────────────────────────────────
# Haslo uzytkownika SYS / ADMIN w kontenerze (ORACLE_PASSWORD wymagane przez gvenzl/oracle-xe)
ORACLE_PASSWORD=zmien_to_haslo_SYS

# Haslo uzytkownika schematu PEGASUS (uzywane w 00_setup_schema.sql i przez testy)
PEGASUS_PASSWORD=zmien_to_haslo_PEGASUS

# ─── Testy (pytest / CI) ──────────────────────────────────────────────────────
# Ponizsze zmienne sa uzywane przez pegasus/tests/test_database.py
# Przy lokalnym uruchomieniu testow: skopiuj wartosci z powyzszych zmiennych
# W GitHub Actions sa ustawiane automatycznie przez ci-tests.yml
#
# ORACLE_SYS_PASSWORD=<ta sama wartosc co ORACLE_PASSWORD>
# PEGASUS_PASSWORD=<ta sama wartosc co PEGASUS_PASSWORD>   (juz ustawiona powyzej)
# DB_HOST=localhost
# DB_PORT=1522
# DB_SERVICE=XEPDB1
